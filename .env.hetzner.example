# Hetzner / docker-compose.hetzner.yml 용
# 사용: 이 파일을 .env.hetzner 로 복사한 뒤 GROQ_API_KEY 만 채운다.
#   cp .env.hetzner.example .env.hetzner
#
# compose 가 QDRANT_HOST=qdrant 등으로 덮어쓰는 값이 있음.
# 여기 값은 env_file 기본 + 비밀키용.

APP_HOST=0.0.0.0
APP_PORT=8010

API_SELECT=3
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# compose environment 가 PATH 비움 + HOST=qdrant 로 덮어씀
QDRANT_PATH=
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=pdf_chunks_bge
QDRANT_COLLECTION_ARKK=arkk_holdings_bge

EMBEDDING_BACKEND=bge-m3
EMBEDDING_MODEL=BAAI/bge-m3
FAKE_EMBED_DIMENSION=32
