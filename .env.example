# API 서버
APP_HOST=0.0.0.0
APP_PORT=8010

# LLM Provider
API_SELECT=3
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Vector Store — 로컬 PATH 우선 (Chroma / LangGraph 학습과 동일 패턴)
# PATH가 있으면 Docker 없이 로컬 폴더 사용. 비우면 HOST:PORT(Docker) 사용.
QDRANT_PATH=D:/vectorData/qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=pdf_chunks_bge
QDRANT_COLLECTION_ARKK=arkk_holdings_bge

# 순번 6 로컬 인제스트 테스트 — data/uploads/ 안 파일명
TEST_UPLOAD_PDF_NAME=01_늑대와 어린양.pdf

# 임베딩 — 운영: bge-m3 / 빠른 단위테스트만: fake
EMBEDDING_BACKEND=bge-m3
EMBEDDING_MODEL=BAAI/bge-m3
FAKE_EMBED_DIMENSION=32
