# API 서버
APP_HOST=0.0.0.0
APP_PORT=8005

# LLM Provider
API_SELECT=3
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Vector Store — 로컬 PATH 우선 (Chroma / LangGraph 학습과 동일 패턴)
# PATH가 있으면 Docker 없이 로컬 폴더 사용. 비우면 HOST:PORT(Docker) 사용.
QDRANT_PATH=D:/vectorData/qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=pdf_chunks
